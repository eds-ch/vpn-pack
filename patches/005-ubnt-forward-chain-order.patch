+// ubntFindForwardInsertPos returns the iptables position number at which
+// a rule should be inserted in the FORWARD chain on UBNT devices — immediately
+// after UBIOS_FORWARD_JUMP. If UBIOS_FORWARD_JUMP is not found, returns 1.
+func ubntFindForwardInsertPos(ipt iptablesInterface) int {
+	rules, err := ipt.List("filter", "FORWARD")
+	if err != nil {
+		return 1
+	}
+	for idx, rule := range rules {
+		if strings.Contains(rule, "-j UBIOS_FORWARD_JUMP") {
+			return idx + 1
+		}
+	}
+	return 1
+}
+
+// ubntEnsureForwardHook ensures -j ts-forward is in FORWARD after
+// UBIOS_FORWARD_JUMP. Handles fresh install, upgrade (misplaced), and no-op.
+func ubntEnsureForwardHook(ipt iptablesInterface) error {
+	args := []string{"-j", "ts-forward"}
+
+	exists, err := ipt.Exists("filter", "FORWARD", args...)
+	if err != nil {
+		return fmt.Errorf("checking ts-forward in filter/FORWARD: %w", err)
+	}
+
+	if exists {
+		if !ubntIsForwardMisplaced(ipt) {
+			return nil
+		}
+		if err := ipt.Delete("filter", "FORWARD", args...); err != nil {
+			return fmt.Errorf("removing misplaced ts-forward: %w", err)
+		}
+	}
+
+	pos := ubntFindForwardInsertPos(ipt)
+	if err := ipt.Insert("filter", "FORWARD", pos, args...); err != nil {
+		return fmt.Errorf("adding ts-forward in filter/FORWARD: %w", err)
+	}
+	return nil
+}
+
+// ubntIsForwardMisplaced reports whether ts-forward appears before
+// UBIOS_FORWARD_JUMP in the FORWARD chain.
+func ubntIsForwardMisplaced(ipt iptablesInterface) bool {
+	rules, err := ipt.List("filter", "FORWARD")
+	if err != nil {
+		return false
+	}
+	ubiosIdx, tsIdx := -1, -1
+	for idx, rule := range rules {
+		if strings.Contains(rule, "-j UBIOS_FORWARD_JUMP") {
+			ubiosIdx = idx
+		}
+		if strings.Contains(rule, "-j ts-forward") {
+			tsIdx = idx
+		}
+	}
+	return ubiosIdx >= 0 && tsIdx >= 0 && tsIdx < ubiosIdx
+}
+
