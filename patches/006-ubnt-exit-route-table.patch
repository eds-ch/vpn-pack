+		args = append(args, "table", r.routeTableNameForPrefix(cidr))
 	}
 	err := r.cmd.run(args...)
 	if err == nil {
@@ -1030,7 +1041,7 @@
 	err = netlink.RouteDel(&netlink.Route{
 		LinkIndex: linkIndex,
 		Dst:       netipx.PrefixIPNet(cidr.Masked()),
-		Table:     r.routeTable(),
+		Table:     r.routeTableForPrefix(cidr),
 	})
 	if errors.Is(err, errESRCH) {
 		// Didn't exist to begin with.
@@ -1057,10 +1068,22 @@
 		Type:  unix.RTN_THROW,
 	})
 	if errors.Is(err, errESRCH) {
-		// Didn't exist to begin with.
-		return nil
+		err = nil
 	}
-	return err
+	if err != nil {
+		return err
+	}
+	if getDistroFunc() == distro.UBNT {
+		exitErr := netlink.RouteDel(&netlink.Route{
+			Dst:   netipx.PrefixIPNet(cidr.Masked()),
+			Table: tailscaleExitRouteTable.Num,
+			Type:  unix.RTN_THROW,
+		})
+		if exitErr != nil && !errors.Is(exitErr, errESRCH) {
+			return exitErr
+		}
+	}
+	return nil
 }
 
