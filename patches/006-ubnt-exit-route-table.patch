+func (r *linuxRouter) routeTableForPrefix(cidr netip.Prefix) int {
+	if getDistroFunc() == distro.UBNT && r.ipRuleAvailable && cidr.Bits() <= 1 {
+		return tailscaleExitRouteTable.Num
+	}
+	return r.routeTable()
+}
+
+func (r *linuxRouter) routeTableNameForPrefix(cidr netip.Prefix) string {
+	if getDistroFunc() == distro.UBNT && r.ipRuleAvailable && cidr.Bits() <= 1 {
+		return tailscaleExitRouteTable.ipCmdArg()
+	}
+	return tailscaleRouteTable.ipCmdArg()
+}
