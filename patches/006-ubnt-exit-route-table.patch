# Tailscale-Version: 1.98.5
# Description: Route /0 exit-node prefixes (catch-all only) to table 53 on UBNT, keeping subnet routes in table 52.
#              Duplicate throw routes into both tables to prevent LAN/WAN breakage with exit nodes.
#              SEC-C16: propagate exit-table throw-route insertion errors instead of swallowing them.
#              SEC-C17: only Bits()==0 (true catch-all) qualifies for table 53; /1 stays in subnet table 52.
--- a/wgengine/router/osrouter/router_linux.go
+++ b/wgengine/router/osrouter/router_linux.go
@@ -953,7 +953,7 @@
 	return netlink.RouteReplace(&netlink.Route{
 		LinkIndex: linkIndex,
 		Dst:       netipx.PrefixIPNet(cidr.Masked()),
-		Table:     r.routeTable(),
+		Table:     r.routeTableForPrefix(cidr),
 	})
 }
 
@@ -978,8 +978,19 @@
 	})
 	if err != nil {
 		r.logf("THROW ERROR adding %v: %#v", cidr, err)
+		return err
 	}
-	return err
+	if getDistroFunc() == distro.UBNT {
+		if err := netlink.RouteReplace(&netlink.Route{
+			Dst:   netipx.PrefixIPNet(cidr.Masked()),
+			Table: tailscaleExitRouteTable.Num,
+			Type:  unix.RTN_THROW,
+		}); err != nil {
+			r.logf("THROW ERROR adding %v to exit table: %#v", cidr, err)
+			return err
+		}
+	}
+	return nil
 }
 
